#!/usr/bin/env bash
# Guard the append-only factory event log.
#
# The cfk binary is NOT rebuilt or committed here — it is built on demand at
# MCP-server launch by plugins/claude-factory/scripts/bootstrap-cfk.sh and is
# gitignored (see ADR 0013). This hook only protects the event store.
set -euo pipefail

# ── Ensure the factory event log is staged ───────────────────────────────────
# The event store under .claude-factory/eventstore/events/ (eventcore-fs, ADR
# 0010) is an append-only log that is the source of truth for project state. New
# or modified event files left unstaged would silently desync the committed
# history from the running state, so refuse to commit while any exist outside the
# index.
UNSTAGED_EVENTS=$(
  {
    git ls-files --others --exclude-standard -- ':(top).claude-factory/eventstore/events/'
    git diff --name-only -- ':(top).claude-factory/eventstore/events/'
  } | sort -u
)
if [[ -n "${UNSTAGED_EVENTS}" ]]; then
  echo "[pre-commit] ERROR: factory event-log files are not staged for commit:" >&2
  echo "${UNSTAGED_EVENTS}" | sed 's/^/  - /' >&2
  echo "[pre-commit] The event log is append-only and must be committed alongside your changes." >&2
  echo "[pre-commit] Stage them with:  git add .claude-factory/eventstore/events" >&2
  exit 1
fi

exit 0
